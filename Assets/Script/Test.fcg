import "StdLibrary.fcc" as std
import "CSVData.fcc" as csv
import "List.fcc" as list
import "Math.fcc" as math
import "Convert.fcc" as convert
import "EditorGenLib.fcc" as EditorGenLib
import "Hud.fcc" as Hud
import UI_Upgrade_Backend from "EditorGenLib.fcc"
import Resource_Management_CLI from "EditorGenLib.fcc"
import "./Touchpad.fcg" as Touchpad

[platform_client]
graph Test {
    // Đây là hàm nén gọn lại toàn bộ đống Block của Sensei
    event OnUpdate() {
        // Lấy UI hiện tại
        var player = GetLocalPlayer()
        var ui = thisEntity<CustomUI>
        
        // Gọi hàm "Lấy và xử lý giá trị nhập trong widget" (đã mã hóa)
        ui<UI_Upgrade_Backend>.Lay_va_xu_ly_gia_tri_nhap_trong_widget(out var thanhCong, out var giaTri)
        
        if (thanhCong) {
            // Đọc bảng CSV và lấy EXP tối đa (Cột 1)
            var expTable = ReadCSVColumn(EResCSV.Level_Upgrade_Prices, 1)
            StringToInt(expTable[Length(expTable) - 1],out var maxExp, out var Thanhcong)
            
            // Lấy thông số nhân vật (Dùng tên hàm đã mã hóa trong Resource_Client_ECA)
            // __LA8ay6sA9N... = Lấy số lượng tiền tệ
            // __DTA9Jc6ch... = Đọc chỉ số nhân vật (Level_EXP = 1)
            var xuHienCo = player<Resource_Management_CLI>.Lay_so_luong_tien_te_nhan_vat_su_dung(ui<UI_Upgrade_Backend>.CharacterID)
            var expHienTai = player<Resource_Management_CLI>.Doc_chi_so_nhan_vat(ui<UI_Upgrade_Backend>.CharacterID, Chi_so_thuoc_tinh.LevelEXP) 
            
            // Logic tính toán Clamp
            var xuCanMax = maxExp - expHienTai
            var giaTriToiDa = math.Min(xuHienCo, xuCanMax)
            var TrueInt = Clamp(giaTri, 0, giaTriToiDa)
            
            // Cập nhật lại kết quả vào biến của UI
            ui<UI_Upgrade_Backend>.So_luong_xu = TrueInt as int
        }
    }
}
